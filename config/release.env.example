# Copy this file to release.local.env or export the variables in your shell.
# Never commit real certificates, passwords, tokens, or keychain files.

# Developer ID signing identity as printed by:
# security find-identity -v -p codesigning
DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"

# Optional: use a notarytool keychain profile that you created locally with:
# xcrun notarytool store-credentials roon-lyric-notary
NOTARY_PROFILE="roon-lyric-notary"

# GitHub target repository, used by script/github_bootstrap.sh.
GITHUB_REPOSITORY="OWNER/roon-lyric"

# Optional fallback for machines without GitHub CLI.
# Create a fine-grained personal access token with repository creation and
# contents write permissions, export it in your shell, and never commit it.
GITHUB_TOKEN="github_pat_xxx"
